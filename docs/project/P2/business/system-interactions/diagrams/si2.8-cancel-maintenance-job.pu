@startuml si2.8-cancel-maintenance-job
title SI2.8 Cancel maintenance job

start
:Receive maintenance job cancellation request;

if (scheduled job can be cancelled?) then ([Yes])
  :Load scheduled maintenance job;
  :Mark job as cancelled;
  :Produce business event
  Maintenance job cancelled; <<sendSignal>>
  :Return success;
  stop
else ([No])
  :Return cancellation validation failure
(job-not-found, job-not-scheduled,
or cancellation-not-allowed);
  stop
endif

@enduml
