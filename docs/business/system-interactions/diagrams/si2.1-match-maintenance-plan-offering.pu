@startuml si2.1-match-maintenance-plan-offering
title SI2.1 Match maintenance plan offering

start
:Receive maintenance plan enrollment request;

if (equipment registered and eligible?) then ([Yes])
  :Load equipment details;
  :Find matching maintenance plan offerings;

  if (matches found?) then ([Yes])
    :Produce business event
Maintenance plan options matched; <<sendSignal>>
    :Return options with pricing;
    stop
  else ([No])
    :Return no match;
    stop
  endif
else ([No])
  :Return equipment validation failure
(equipment-not-found, equipment-not-registered,
or equipment-ineligible);
  stop
endif

@enduml
