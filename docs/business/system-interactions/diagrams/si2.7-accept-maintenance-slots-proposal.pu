@startuml si2.7-accept-maintenance-slots-proposal
title SI2.7 Accept maintenance slots proposal

start
:Receive selected maintenance slot request;

if (proposal and selected slot valid?) then ([Yes])
  :Load maintenance slots proposal;
  :Remove reserved slots from proposal;
  :Schedule accepted maintenance slot;
  :Produce business event
Maintenance job scheduled; <<sendSignal>>
  :Return scheduled maintenance slot;
  stop
else ([No])
  :Return selected-slot validation failure
(proposal-not-found, proposal-not-selectable,
selected-slot-not-in-proposal, or selected-slot-unavailable);
  stop
endif

@enduml
