@startuml si1.1-register-account
title SI1.1 Register account

start
:Consume business event
Register account requested;

if (valid email and account not already registered?) then ([Yes])
  :Create user account in unconfirmed state;
  :Create email confirmation token;
  :Produce business event
User account registered pending email confirmation;
  :Return registration accepted;
  stop
else ([No])
  :Return failure;
  stop
endif

@enduml
