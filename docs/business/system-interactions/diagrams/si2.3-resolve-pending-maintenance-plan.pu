@startuml si2.3-resolve-pending-maintenance-plan
title SI2.3 Resolve pending maintenance plan

start
:Consume event
Maintenance plan request rejected or agreement signed; <<acceptEvent>>

if (maintenance plan resolution valid?) then ([Yes])
  if (is activation?) then ([Yes])
    :Attach customer-signed agreement;
    :Mark maintenance plan as active;
    :Produce business event
Maintenance plan activated; <<sendSignal>>
    stop
  else ([No, rejection])
    :Store rejection reason if provided;
    :Mark maintenance plan as rejected;
    :Produce business event
Maintenance plan rejected; <<sendSignal>>
    stop
  endif
else ([No])
  :Nack event to DLQ <<sendSignal>>
resolution validation failure
(invalid-outcome, plan-not-found, already-resolved,
or missing-signature-evidence);
  stop
endif

@enduml
