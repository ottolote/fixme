@startuml si3.4-activate-maintenance-plan
title SI3.4 Activate maintenance plan

start
:Receive signed maintenance plan event;

if (signed document valid and plan pending activation?) then ([Yes])
  :Load pending maintenance plan;
  :Attach signed agreement;
  :Mark maintenance plan as active;
  :Return active maintenance plan;
  stop
else ([No])
  :Return failure;
  stop
endif

@enduml
