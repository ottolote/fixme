@startuml si3.3-reject-maintenance-plan
title SI3.3 Reject maintenance plan

start
:Receive reject maintenance plan command;

if (pending plan can be rejected?) then ([Yes])
  :Load pending maintenance plan;
  :Mark maintenance plan as rejected;
  :Store rejection reason if provided;
  :Return success;
  stop
else ([No])
  :Return failure;
  stop
endif

@enduml
